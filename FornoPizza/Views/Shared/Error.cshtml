@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка — FORNO";
}

<header class="top">
    <a class="logo" asp-controller="Home" asp-action="Index">FORNO</a>
</header>

<main style="padding: 1rem 6vw 4rem;">
    <section class="panel">
        <div class="step-head">
            <span class="step-num">!</span>
            <div>
                <h2>Что-то пошло не так</h2>
                <p>Произошла ошибка при обработке запроса.</p>
            </div>
        </div>

        @if (Model.ShowRequestId)
        {
            <p>
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }
    </section>
</main>

<footer class="footer">
    <span>FORNO · пицца из настоящей печи</span>
    <span>Ежедневно 11:00–23:00</span>
</footer>
